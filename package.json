{
  "name": "lms-frontend",
  "version": "1.0.0",
  "main": "index.ts",
  "description": "LMS Frontend - React Native App with Expo, TypeScript, and NativeWind",
  "author": "Techsoul",
  "license": "MIT",
  "scripts": {
    "start": "expo start -c",
    "start:web": "expo start --web",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "preview": "expo prebuild --clean",
    "prebuild": "expo prebuild --clean",
    "build:android": "expo run:android",
    "build:ios": "expo run:ios",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^7.14.0",
    "@react-navigation/drawer": "^7.8.1",
    "@react-navigation/native": "^7.1.8",
    "@reduxjs/toolkit": "^1.9.7",
    "clsx": "^2.1.1",
    "expo": "~54.0.33",
    "expo-font": "~14.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-screen-orientation": "~9.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "nativewind": "^4.2.2",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-worklets": "^0.7.4",
    "react-redux": "^8.1.3",
    "redux": "^4.2.1",
    "tailwindcss": "^3.4.19"
